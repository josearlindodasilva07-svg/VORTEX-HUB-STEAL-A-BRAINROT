    local startPos = hrp.Position
    local targetPos = targetPart.Position + Vector3.new(0, 2, 0)
    local distance = (targetPos - startPos).Magnitude
    local steps = math.max(20, math.floor(distance / 3))
    local delay = 0.04
    
    for i = 1, steps do
        local alpha = i / steps
        
        local newX = startPos.X + ((targetPos.X - startPos.X) * alpha)
        local newZ = startPos.Z + ((targetPos.Z - startPos.Z) * alpha)
        local newY = startPos.Y + ((targetPos.Y - startPos.Y) * alpha)
        
        local velX = (newX - hrp.Position.X) / delay
        local velY = (newY - hrp.Position.Y) / delay
        local velZ = (newZ - hrp.Position.Z) / delay
        
        hrp.AssemblyLinearVelocity = Vector3.new(velX, velY, velZ)
        task.wait(delay)
    end
    
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.CFrame = CFrame.new(targetPos)
    
    ShowNotification("TP", "Chegou no brainrot!")
end)

